# Guardian VPS profile — copy to .env on your server
# Domain: guardian.example.com → A record → this server's public IP

GUARDIAN_DEPLOY_MODE=vps
GUARDIAN_PUBLIC_HOST=guardian.example.com
GUARDIAN_PUBLIC_PORT=443
GUARDIAN_BIND_HOST=127.0.0.1

# Block unauthenticated test-alert injection on public deployments
GUARDIAN_DISABLE_TEST_ALERT=1

# Live breach checks
GUARDIAN_BREACH_PROVIDER=auto
GUARDIAN_INSECURE_SSL=0

# Rate limit per client IP on VPS (requests/minute)
GUARDIAN_RATE_LIMIT=120

# Let's Encrypt (after: certbot certonly --nginx -d guardian.example.com)
GUARDIAN_TLS_CERT=/etc/letsencrypt/live/guardian.example.com/fullchain.pem
GUARDIAN_TLS_KEY=/etc/letsencrypt/live/guardian.example.com/privkey.pem

# Optional production keys
# HIBP_API_KEY=
# GUARDIAN_MASTER_KEY=
