# Guardian VPS profile — copy to .env on your server
# Domain: guardian.learniam.online → A record → this server's public IP

GUARDIAN_DEPLOY_MODE=vps
GUARDIAN_PUBLIC_HOST=guardian.learniam.online
GUARDIAN_PUBLIC_PORT=443
GUARDIAN_BIND_HOST=0.0.0.0

# Live breach checks
GUARDIAN_BREACH_PROVIDER=auto
GUARDIAN_INSECURE_SSL=0

# Rate limit per client IP on VPS (requests/minute)
GUARDIAN_RATE_LIMIT=120

# Let's Encrypt (after: certbot certonly --nginx -d guardian.learniam.online)
GUARDIAN_TLS_CERT=/etc/letsencrypt/live/guardian.learniam.online/fullchain.pem
GUARDIAN_TLS_KEY=/etc/letsencrypt/live/guardian.learniam.online/privkey.pem

# Optional production keys
# HIBP_API_KEY=
# GUARDIAN_MASTER_KEY=
