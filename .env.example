# Guardian — copy to .env and fill in for production (optional; export vars work too)

# ─── Web server ───────────────────────────────────────────────────────────────
# Corporate SSL proxy / broken TLS interception
GUARDIAN_INSECURE_SSL=1

# ─── Personal breach check ────────────────────────────────────────────────────
# Provider: mock | auto | xposedornot | hibp
#   auto  = HIBP if HIBP_API_KEY set, else multi (XposedOrNot + HackMyIP, free)
GUARDIAN_BREACH_PROVIDER=auto

# Free multi-source daily limit (auto without HIBP key uses multi)
GUARDIAN_MULTI_DAILY_LIMIT=100

# Shorthand: same as auto when no provider is set
# GUARDIAN_BREACH_LIVE=1

# Have I Been Pwned (paid) — https://haveibeenpwned.com/API/Key
# HIBP_API_KEY=your-key-here
# Free test key (only @hibp-integration-tests.com emails): 00000000000000000000000000000000

# Free tier daily limits (Guardian-side counter; resets UTC midnight)
GUARDIAN_XON_DAILY_LIMIT=100
# GUARDIAN_HIBP_DAILY_LIMIT=500

# ─── Optional enrichers (Threat Feed cross-verify) ───────────────────────────
# ABUSEIPDB_API_KEY=
# NVD_API_KEY=
# ABUSE_CH_AUTH_KEY=
