# Guardian — copy to .env and fill in for production
# Quick start:  cp .env.example .env   (or run ./scripts/setup-env.sh)

# ─── Web server ───────────────────────────────────────────────────────────────
# Corporate SSL proxy / broken TLS interception (needed on many corporate networks)
GUARDIAN_INSECURE_SSL=1

# ─── Personal breach check (live by default) ──────────────────────────────────
# Provider: mock | auto | xposedornot | multi | hibp
#   auto  = HIBP if HIBP_API_KEY set, else multi (XposedOrNot + HackMyIP, free)
#   mock  = fictional demo data for QA only
GUARDIAN_BREACH_PROVIDER=auto

# Free multi-source daily limit (auto without HIBP key uses multi)
GUARDIAN_MULTI_DAILY_LIMIT=100

# Shorthand: same as auto when GUARDIAN_BREACH_PROVIDER is unset
# GUARDIAN_BREACH_LIVE=1

# Have I Been Pwned (paid) — https://haveibeenpwned.com/API/Key
# When set, auto prefers HIBP for production email lookups.
# HIBP_API_KEY=your-key-here
# Free test key (only @hibp-integration-tests.com emails): 00000000000000000000000000000000

# Free tier daily limits (Guardian-side counter; resets UTC midnight)
GUARDIAN_XON_DAILY_LIMIT=100
# GUARDIAN_HIBP_DAILY_LIMIT=500

# ─── Deployment (local PC vs VPS) ─────────────────────────────────────────────
# local = dashboard on this machine (http://127.0.0.1:8765)
# vps   = public subdomain (https://guardian.learniam.online)
GUARDIAN_DEPLOY_MODE=local
# GUARDIAN_PUBLIC_HOST=guardian.learniam.online
# GUARDIAN_PUBLIC_PORT=443
# GUARDIAN_PUBLIC_URL=https://guardian.learniam.online/
# GUARDIAN_BIND_HOST=0.0.0.0
# VPS template: cp .env.vps.example .env  — see docs/deployment-learniam.md

# ─── TLS / HTTPS (enable when binding beyond localhost) ───────────────────────
# Self-signed cert auto-generated in ~/.guardian/tls/ (requires openssl).
# GUARDIAN_TLS_AUTO=1
# Or supply your own certificate pair:
# GUARDIAN_TLS_CERT=/path/to/fullchain.pem
# GUARDIAN_TLS_KEY=/path/to/privkey.pem
# Example: bind on LAN —  python -m guardian.cli serve --host 0.0.0.0
#          with GUARDIAN_TLS_AUTO=1 in .env, open https://YOUR_IP:8765/

# ─── Security (E2E + API auth — on by default when cryptography is installed) ─
# GUARDIAN_MASTER_KEY=          # 64-char hex or base64url; else ~/.guardian/master.key
# GUARDIAN_API_AUTH=1           # require session token on /api/* (set 0 for dev only)
# GUARDIAN_ALLOW_PLAINTEXT=0    # set 1 to allow unencrypted API payloads (dev only)
# GUARDIAN_REQUIRE_E2E=1        # reject plaintext breach-check requests when E2E is available

# ─── Optional enrichers (Threat Feed cross-verify) ───────────────────────────
# ABUSEIPDB_API_KEY=
# NVD_API_KEY=
# ABUSE_CH_AUTH_KEY=